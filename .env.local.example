# Notion API
NOTION_API_KEY=
NOTION_WORKOUT_DATABASE_ID=
NOTION_FOOD_DATABASE_ID=
NOTION_LIFELOG_DATABASE_ID=

# Google Gemini API
GEMINI_API_KEY=

# OpenWeather API (https://openweathermap.org/)
OPENWEATHER_API_KEY=
OPENWEATHER_CITY=Tokyo

# Fitbit API (https://dev.fitbit.com/)
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_ACCESS_TOKEN=   # 初回は /api/fitbit/auth にアクセスして取得
FITBIT_REFRESH_TOKEN=  # 同上。以降は自動更新

# Notion Config DB（Fitbit トークンの永続化に使用）
# Key / Value の2カラムを持つ Notion DB の ID を設定する
NOTION_CONFIG_DATABASE_ID=

# アプリのベース URL（Fitbit OAuth コールバック用）
# Vercel では自動設定されるため通常は不要。ローカル開発時に設定
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Demo mode (set to "true" to use dummy data without Notion/Gemini API keys)
# NEXT_PUBLIC_DEMO_MODE=true
